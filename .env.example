# Storefront (apps/storefront) — copy to apps/storefront/.env.local

NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
STRAPI_API_URL=http://localhost:1337
STRAPI_REVALIDATE_SECONDS=60
# STRAPI_API_TOKEN=

# Strapi CMS (apps/strapi) — copy to apps/strapi/.env
# See apps/strapi/.env.example
NOVELLA_CONTACT_EMAIL=yonngelay@gmail.com
NOVELLA_CONTACT_NAME=Shwe Yee Winn

# Session cookie signing (use a long random string in production)
SESSION_SECRET=change-me-in-production

# Admin API + panel (optional)
ADMIN_SECRET=dev-admin-secret

# Default user created by: npm run seed:user
SEED_USER_NAME=Novella Demo
SEED_USER_EMAIL=demo@novella.local
SEED_USER_PASSWORD=novella-demo
