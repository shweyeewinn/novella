{
  "kind": "collectionType",
  "collectionName": "blog_posts",
  "info": {
    "singularName": "blog-post",
    "pluralName": "blog-posts",
    "displayName": "Blog post",
    "description": "Editorial posts for /blog"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "excerpt": {
      "type": "text",
      "required": true
    },
    "body": {
      "type": "richtext",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": ["reading", "authors", "publishing", "community"],
      "default": "reading",
      "required": true
    },
    "author": {
      "type": "string",
      "required": true
    },
    "publishedAt": {
      "type": "datetime",
      "required": true
    },
    "readingMinutes": {
      "type": "integer",
      "default": 5
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "coverHue": {
      "type": "integer"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    }
  }
}
