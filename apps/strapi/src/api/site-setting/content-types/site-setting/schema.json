{
  "kind": "singleType",
  "collectionName": "site_settings",
  "info": {
    "singularName": "site-setting",
    "pluralName": "site-settings",
    "displayName": "Site settings",
    "description": "Storefront copy, contact, and bank transfer details"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "siteName": {
      "type": "string",
      "default": "Novella",
      "required": true
    },
    "tagline": {
      "type": "string",
      "required": true
    },
    "ownerName": {
      "type": "string",
      "required": true
    },
    "ownerEmail": {
      "type": "email",
      "required": true
    },
    "bankName": {
      "type": "string",
      "required": true
    },
    "accountName": {
      "type": "string",
      "required": true
    },
    "accountNumber": {
      "type": "string",
      "required": true
    },
    "transferNote": {
      "type": "text"
    }
  }
}
